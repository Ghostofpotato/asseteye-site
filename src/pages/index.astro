---
import Layout from '../layouts/Layout.astro';
---
<Layout title="AssetEye — AI-Powered Drone Inspections">

  <!-- FIXED: Drone trail + ambient particles -->
  <canvas id="fx-canvas" aria-hidden="true"></canvas>

  <!-- NAV -->
  <nav class="nav">
    <div class="nav-logo">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none">
        <circle cx="16" cy="16" r="10" stroke="#77B940" stroke-width="1.5"/>
        <circle cx="16" cy="16" r="5" stroke="#B1D794" stroke-width="1"/>
        <circle cx="16" cy="16" r="2" fill="#B1D794"/>
      </svg>
      <span>AssetEye</span>
    </div>
    <div class="nav-center">
      <a href="#capabilities">Capabilities</a>
      <a href="#process">Process</a>
      <a href="#proof">Results</a>
    </div>
    <a href="#cta" class="nav-cta" data-magnetic>Book a Demo</a>
  </nav>

  <!-- ═══════ HERO ═══════ -->
  <section class="hero" data-act="hero">
    <div class="hero-bg">
      <div class="hero-grid"></div>
      <div class="hero-radial"></div>
      <div class="hero-noise"></div>
    </div>
    <div class="hero-content">
      <div class="spline-wrapper">
        <canvas id="spline-canvas"></canvas>
        <div class="spline-overlay"></div>
        <div class="spline-fade"></div>
      </div>
      <div class="hero-eyebrow"><span class="eyebrow-dot"></span>Now with AI-powered 3D modeling</div>
      <h1 class="reveal-text">
        <span class="rt-line"><span class="rt-inner">See Everything.</span></span>
        <span class="rt-line"><span class="rt-inner">Miss Nothing.</span></span>
      </h1>
      <p class="hero-sub">Autonomous drone inspections that turn raw scans into 3D models, AI-powered defect reports, and actionable intelligence — in under 60 seconds.</p>
      <div class="hero-actions">
        <a href="#cta" class="btn-fill" data-magnetic><span>Book a Demo</span></a>
        <a href="#capabilities" class="btn-outline" data-magnetic>
          <span>Explore Capabilities</span>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M8 3v10m0 0l-3-3m3 3l3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <div class="hero-proof">
        <div class="hp-item"><strong>50,000+</strong> inspections</div>
        <div class="hp-divider"></div>
        <div class="hp-item"><strong>98.7%</strong> accuracy</div>
        <div class="hp-divider"></div>
        <div class="hp-item"><strong>12</strong> countries</div>
      </div>
    </div>
    <div class="scroll-cue"><div class="scroll-cue-line"></div></div>
  </section>

  <!-- ═══════ PROBLEM ═══════ -->
  <section class="section-problem" data-act="problem">
    <div class="container">
      <div class="problem-layout">
        <div class="problem-left">
          <p class="label">The Problem</p>
          <h2 class="reveal-text">
            <span class="rt-line"><span class="rt-inner">Traditional inspections</span></span>
            <span class="rt-line"><span class="rt-inner">are broken.</span></span>
          </h2>
          <p class="sub-text">Manual methods are slow, dangerous, and miss up to 73% of critical defects. Infrastructure ages faster than teams can inspect it.</p>
          <div class="problem-phrases">
            <div class="phrase-item active">Slow & dangerous manual climbs</div>
            <div class="phrase-item">73% of critical defects missed</div>
            <div class="phrase-item">$4.2 billion lost every year</div>
            <div class="phrase-item">14-day average response delay</div>
          </div>
        </div>
        <div class="problem-right">
          <div class="p-stat">
            <div class="p-stat-num" data-count="4.2" data-prefix="$" data-suffix="B" data-decimals="1">$0B</div>
            <div class="p-stat-bar"><div class="p-stat-fill" data-w="85"></div></div>
            <p>Lost annually to undetected failures</p>
          </div>
          <div class="p-stat">
            <div class="p-stat-num" data-count="73" data-suffix="%">0%</div>
            <div class="p-stat-bar"><div class="p-stat-fill" data-w="73"></div></div>
            <p>Of inspections miss critical defects</p>
          </div>
          <div class="p-stat">
            <div class="p-stat-num" data-count="14" data-suffix=" days">0 days</div>
            <div class="p-stat-bar"><div class="p-stat-fill" data-w="55"></div></div>
            <p>Average delay before action is taken</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ CAPABILITIES — Interactive Cards with Video ═══════ -->
  <section class="section-caps" id="capabilities" data-act="caps">
    <div class="container">
      <div class="caps-header">
        <p class="label">Capabilities</p>
        <h2 class="reveal-text">
          <span class="rt-line"><span class="rt-inner">Everything you need.</span></span>
          <span class="rt-line"><span class="rt-inner">Nothing you don't.</span></span>
        </h2>
      </div>
      <div class="caps-grid">
        <!-- Card 1: AI Detection -->
        <div class="cap-card" data-tilt>
          <div class="cap-card-visual">
            <img src="/asseteye-site/images/detect.jpg" alt="AI defect detection" class="cap-img" />
            <div class="cap-img-overlay"></div>
            <div class="detect-scanbar"></div>
          </div>
          <div class="cap-card-body">
            <div class="cap-tag">AI Engine</div>
            <h3>Real-Time Defect Detection</h3>
            <p>Computer vision trained on 2M+ infrastructure images. Identifies cracks, corrosion, deformation, thermal anomalies, and vegetation encroachment — as the drone flies.</p>
            <div class="cap-metric"><span>98.7%</span> detection accuracy</div>
          </div>
          <div class="cap-card-glow"></div>
          <div class="cap-card-border"></div>
        </div>

        <!-- Card 2: 3D Modeling -->
        <div class="cap-card" data-tilt>
          <div class="cap-card-visual">
            <img src="/asseteye-site/images/model.jpg" alt="3D photogrammetry model" class="cap-img" />
            <div class="cap-img-overlay"></div>
          </div>
          <div class="cap-card-body">
            <div class="cap-tag">3D Engine</div>
            <h3>Photogrammetric 3D Modeling</h3>
            <p>Thousands of aerial images stitched into centimeter-accurate 3D models. Measure, annotate, and share digital twins of any asset — bridge, tower, pipeline, or roof.</p>
            <div class="cap-metric"><span>±2cm</span> model accuracy</div>
          </div>
          <div class="cap-card-glow"></div>
          <div class="cap-card-border"></div>
        </div>

        <!-- Card 3: Automated Reports -->
        <div class="cap-card" data-tilt>
          <div class="cap-card-visual">
            <img src="/asseteye-site/images/report.jpg" alt="AI-generated inspection reports" class="cap-img" />
            <div class="cap-img-overlay"></div>
          </div>
          <div class="cap-card-body">
            <div class="cap-tag">Reports</div>
            <h3>Instant AI-Generated Reports</h3>
            <p>From raw drone data to prioritized, actionable PDF reports with annotated images, severity scores, GPS coordinates, and recommended actions — in under 60 seconds.</p>
            <div class="cap-metric"><span>&lt; 60s</span> scan to report</div>
          </div>
          <div class="cap-card-glow"></div>
          <div class="cap-card-border"></div>
        </div>

        <!-- Card 4: Autonomous Flight -->
        <div class="cap-card" data-tilt>
          <div class="cap-card-visual">
            <img src="/asseteye-site/images/flight.jpg" alt="Autonomous drone flight" class="cap-img" />
            <div class="cap-img-overlay"></div>
          </div>
          <div class="cap-card-body">
            <div class="cap-tag">Autonomy</div>
            <h3>Fully Autonomous Flight</h3>
            <p>Program flight paths once. GPS-guided drones execute missions autonomously — obstacle avoidance, wind compensation, and battery-swap coordination built in.</p>
            <div class="cap-metric"><span>100%</span> autonomous operation</div>
          </div>
          <div class="cap-card-glow"></div>
          <div class="cap-card-border"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ HOW IT WORKS — Pinned cinematic scroll ═══════ -->
  <section class="section-how" id="process" data-act="how">
    <div class="how-pin">
      <div class="how-scene active" data-scene="0">
        <div class="how-scene-bg"><canvas class="scene-cv" data-sid="0"></canvas></div>
        <div class="how-scene-content">
          <div class="hsc-number">01</div>
          <h3 class="hsc-title">Deploy Your Fleet</h3>
          <p class="hsc-desc">One tap. AI calculates optimal flight paths for complete coverage. Your drone fleet launches autonomously, adapting to weather and terrain in real-time.</p>
          <div class="hsc-facts">
            <div class="hsc-fact"><strong>12 min</strong><span>avg. deployment</span></div>
            <div class="hsc-fact"><strong>100%</strong><span>area coverage</span></div>
          </div>
        </div>
        <div class="how-scene-visual deploy-free">
          <svg class="deploy-scene" viewBox="0 0 500 420" fill="none">
            <defs>
              <linearGradient id="bodyG" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#8fce55"/><stop offset="100%" stop-color="#5a9a2a"/></linearGradient>
              <linearGradient id="armG" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#6fb03a"/><stop offset="100%" stop-color="#4a8a20"/></linearGradient>
              <linearGradient id="roofG" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#5a4a3a"/><stop offset="100%" stop-color="#3d3228"/></linearGradient>
              <linearGradient id="wallG" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#f5efe6"/><stop offset="100%" stop-color="#e0d8cc"/></linearGradient>
              <filter id="dShadow"><feDropShadow dx="0" dy="4" stdDeviation="3" flood-color="#000" flood-opacity="0.15"/></filter>
              <filter id="hShadow"><feDropShadow dx="2" dy="4" stdDeviation="5" flood-color="#000" flood-opacity="0.12"/></filter>
              <radialGradient id="rotorBlur"><stop offset="0%" stop-color="#B1D794" stop-opacity="0.5"/><stop offset="100%" stop-color="#B1D794" stop-opacity="0"/></radialGradient>
            </defs>
            <!-- ═══ Scandinavian House (isometric) ═══ -->
            <g filter="url(#hShadow)" transform="translate(180,240)">
              <!-- Ground shadow -->
              <ellipse cx="70" cy="145" rx="90" ry="15" fill="rgba(0,0,0,0.06)"/>
              <!-- Front wall -->
              <path d="M0,60 L0,140 L140,140 L140,60 Z" fill="url(#wallG)" stroke="#c8bfb0" stroke-width="0.8"/>
              <!-- Side wall (perspective) -->
              <path d="M140,60 L200,40 L200,120 L140,140 Z" fill="#ddd4c6" stroke="#c8bfb0" stroke-width="0.8"/>
              <!-- Roof front -->
              <path d="M-8,60 L70,5 L148,60 Z" fill="url(#roofG)" stroke="#4a3f33" stroke-width="0.8"/>
              <!-- Roof side -->
              <path d="M148,60 L208,40 L130,-15 L70,5 Z" fill="#4d4035" stroke="#4a3f33" stroke-width="0.8"/>
              <!-- Chimney -->
              <rect x="100" y="-5" width="16" height="30" fill="#6b5d50" rx="1"/>
              <rect x="98" y="-8" width="20" height="5" fill="#7a6b5c" rx="1"/>
              <!-- Windows -->
              <rect x="18" y="75" width="28" height="35" rx="2" fill="#a8d8ea" stroke="#8ab0c0" stroke-width="1" opacity="0.9"/>
              <line x1="32" y1="75" x2="32" y2="110" stroke="#8ab0c0" stroke-width="0.8"/>
              <line x1="18" y1="92" x2="46" y2="92" stroke="#8ab0c0" stroke-width="0.8"/>
              <rect x="58" y="75" width="28" height="35" rx="2" fill="#a8d8ea" stroke="#8ab0c0" stroke-width="1" opacity="0.9"/>
              <line x1="72" y1="75" x2="72" y2="110" stroke="#8ab0c0" stroke-width="0.8"/>
              <line x1="58" y1="92" x2="86" y2="92" stroke="#8ab0c0" stroke-width="0.8"/>
              <!-- Door -->
              <rect x="100" y="95" width="26" height="45" rx="3" fill="#6b5d50" stroke="#5a4e42" stroke-width="1"/>
              <circle cx="122" cy="118" r="2" fill="#b8a890"/>
              <!-- Window glow -->
              <rect x="20" y="77" width="24" height="31" rx="1" fill="rgba(168,216,234,0.15)"/>
              <rect x="60" y="77" width="24" height="31" rx="1" fill="rgba(168,216,234,0.15)"/>
              <!-- Side windows -->
              <rect x="155" y="55" width="20" height="28" rx="2" fill="#a8d8ea" stroke="#8ab0c0" stroke-width="0.8" opacity="0.7"/>
              <rect x="155" y="95" width="20" height="20" rx="2" fill="#a8d8ea" stroke="#8ab0c0" stroke-width="0.8" opacity="0.6"/>
            </g>
            <!-- ═══ 3D Drone 1 (large, front) ═══ -->
            <g class="free-drone fd-1" filter="url(#dShadow)">
              <g transform="translate(250,55)">
                <!-- Rotor blur discs -->
                <ellipse cx="-38" cy="-4" rx="18" ry="5" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="38" cy="-4" rx="18" ry="5" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="-38" cy="18" rx="18" ry="5" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="38" cy="18" rx="18" ry="5" fill="url(#rotorBlur)" class="rotor-disc"/>
                <!-- Arms -->
                <line x1="-10" y1="2" x2="-38" y2="-4" stroke="url(#armG)" stroke-width="4" stroke-linecap="round"/>
                <line x1="10" y1="2" x2="38" y2="-4" stroke="url(#armG)" stroke-width="4" stroke-linecap="round"/>
                <line x1="-10" y1="12" x2="-38" y2="18" stroke="url(#armG)" stroke-width="4" stroke-linecap="round"/>
                <line x1="10" y1="12" x2="38" y2="18" stroke="url(#armG)" stroke-width="4" stroke-linecap="round"/>
                <!-- Motor hubs -->
                <circle cx="-38" cy="-4" r="4" fill="#5a9a2a" stroke="#4a8a20" stroke-width="1"/>
                <circle cx="38" cy="-4" r="4" fill="#5a9a2a" stroke="#4a8a20" stroke-width="1"/>
                <circle cx="-38" cy="18" r="4" fill="#5a9a2a" stroke="#4a8a20" stroke-width="1"/>
                <circle cx="38" cy="18" r="4" fill="#5a9a2a" stroke="#4a8a20" stroke-width="1"/>
                <!-- Body (3D rounded) -->
                <ellipse cx="0" cy="7" rx="16" ry="10" fill="url(#bodyG)"/>
                <ellipse cx="0" cy="5" rx="12" ry="6" fill="#8fce55" opacity="0.4"/>
                <!-- Camera gimbal -->
                <rect x="-4" y="14" width="8" height="5" rx="2" fill="#4a4a4a"/>
                <circle cx="0" cy="19" r="3" fill="#333" stroke="#555" stroke-width="0.5"/>
                <circle cx="0" cy="19" r="1.5" fill="#77B940" opacity="0.8"/>
                <!-- LED lights -->
                <circle cx="-8" cy="0" r="1.2" fill="#ff3333" opacity="0.8"/>
                <circle cx="8" cy="0" r="1.2" fill="#00cc44" opacity="0.8"/>
              </g>
            </g>
            <!-- ═══ 3D Drone 2 (left) ═══ -->
            <g class="free-drone fd-2" filter="url(#dShadow)">
              <g transform="translate(80,110) scale(0.8)">
                <ellipse cx="-32" cy="-3" rx="15" ry="4" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="32" cy="-3" rx="15" ry="4" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="-32" cy="15" rx="15" ry="4" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="32" cy="15" rx="15" ry="4" fill="url(#rotorBlur)" class="rotor-disc"/>
                <line x1="-8" y1="2" x2="-32" y2="-3" stroke="url(#armG)" stroke-width="3.5" stroke-linecap="round"/>
                <line x1="8" y1="2" x2="32" y2="-3" stroke="url(#armG)" stroke-width="3.5" stroke-linecap="round"/>
                <line x1="-8" y1="10" x2="-32" y2="15" stroke="url(#armG)" stroke-width="3.5" stroke-linecap="round"/>
                <line x1="8" y1="10" x2="32" y2="15" stroke="url(#armG)" stroke-width="3.5" stroke-linecap="round"/>
                <circle cx="-32" cy="-3" r="3.5" fill="#5a9a2a" stroke="#4a8a20" stroke-width="0.8"/>
                <circle cx="32" cy="-3" r="3.5" fill="#5a9a2a" stroke="#4a8a20" stroke-width="0.8"/>
                <circle cx="-32" cy="15" r="3.5" fill="#5a9a2a" stroke="#4a8a20" stroke-width="0.8"/>
                <circle cx="32" cy="15" r="3.5" fill="#5a9a2a" stroke="#4a8a20" stroke-width="0.8"/>
                <ellipse cx="0" cy="6" rx="14" ry="9" fill="url(#bodyG)"/>
                <rect x="-3" y="12" width="6" height="4" rx="1.5" fill="#4a4a4a"/>
                <circle cx="0" cy="16" r="2.5" fill="#333"/>
                <circle cx="0" cy="16" r="1.2" fill="#77B940" opacity="0.7"/>
              </g>
            </g>
            <!-- ═══ 3D Drone 3 (right) ═══ -->
            <g class="free-drone fd-3" filter="url(#dShadow)">
              <g transform="translate(420,130) scale(0.75)">
                <ellipse cx="-32" cy="-3" rx="15" ry="4" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="32" cy="-3" rx="15" ry="4" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="-32" cy="15" rx="15" ry="4" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="32" cy="15" rx="15" ry="4" fill="url(#rotorBlur)" class="rotor-disc"/>
                <line x1="-8" y1="2" x2="-32" y2="-3" stroke="url(#armG)" stroke-width="3.5" stroke-linecap="round"/>
                <line x1="8" y1="2" x2="32" y2="-3" stroke="url(#armG)" stroke-width="3.5" stroke-linecap="round"/>
                <line x1="-8" y1="10" x2="-32" y2="15" stroke="url(#armG)" stroke-width="3.5" stroke-linecap="round"/>
                <line x1="8" y1="10" x2="32" y2="15" stroke="url(#armG)" stroke-width="3.5" stroke-linecap="round"/>
                <circle cx="-32" cy="-3" r="3.5" fill="#5a9a2a" stroke="#4a8a20" stroke-width="0.8"/>
                <circle cx="32" cy="-3" r="3.5" fill="#5a9a2a" stroke="#4a8a20" stroke-width="0.8"/>
                <circle cx="-32" cy="15" r="3.5" fill="#5a9a2a" stroke="#4a8a20" stroke-width="0.8"/>
                <circle cx="32" cy="15" r="3.5" fill="#5a9a2a" stroke="#4a8a20" stroke-width="0.8"/>
                <ellipse cx="0" cy="6" rx="14" ry="9" fill="url(#bodyG)"/>
                <rect x="-3" y="12" width="6" height="4" rx="1.5" fill="#4a4a4a"/>
                <circle cx="0" cy="16" r="2.5" fill="#333"/>
                <circle cx="0" cy="16" r="1.2" fill="#77B940" opacity="0.7"/>
              </g>
            </g>
            <!-- ═══ Drone 4 (smaller, far left) ═══ -->
            <g class="free-drone fd-4" filter="url(#dShadow)">
              <g transform="translate(45,210) scale(0.55)">
                <ellipse cx="-30" cy="0" rx="13" ry="3.5" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="30" cy="0" rx="13" ry="3.5" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="-30" cy="14" rx="13" ry="3.5" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="30" cy="14" rx="13" ry="3.5" fill="url(#rotorBlur)" class="rotor-disc"/>
                <line x1="-7" y1="3" x2="-30" y2="0" stroke="url(#armG)" stroke-width="3" stroke-linecap="round"/>
                <line x1="7" y1="3" x2="30" y2="0" stroke="url(#armG)" stroke-width="3" stroke-linecap="round"/>
                <line x1="-7" y1="10" x2="-30" y2="14" stroke="url(#armG)" stroke-width="3" stroke-linecap="round"/>
                <line x1="7" y1="10" x2="30" y2="14" stroke="url(#armG)" stroke-width="3" stroke-linecap="round"/>
                <circle cx="-30" cy="0" r="3" fill="#5a9a2a"/><circle cx="30" cy="0" r="3" fill="#5a9a2a"/>
                <circle cx="-30" cy="14" r="3" fill="#5a9a2a"/><circle cx="30" cy="14" r="3" fill="#5a9a2a"/>
                <ellipse cx="0" cy="6" rx="12" ry="8" fill="url(#bodyG)"/>
              </g>
            </g>
            <!-- ═══ Drone 5 (smaller, far right) ═══ -->
            <g class="free-drone fd-5" filter="url(#dShadow)">
              <g transform="translate(460,230) scale(0.5)">
                <ellipse cx="-30" cy="0" rx="13" ry="3.5" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="30" cy="0" rx="13" ry="3.5" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="-30" cy="14" rx="13" ry="3.5" fill="url(#rotorBlur)" class="rotor-disc"/>
                <ellipse cx="30" cy="14" rx="13" ry="3.5" fill="url(#rotorBlur)" class="rotor-disc"/>
                <line x1="-7" y1="3" x2="-30" y2="0" stroke="url(#armG)" stroke-width="3" stroke-linecap="round"/>
                <line x1="7" y1="3" x2="30" y2="0" stroke="url(#armG)" stroke-width="3" stroke-linecap="round"/>
                <line x1="-7" y1="10" x2="-30" y2="14" stroke="url(#armG)" stroke-width="3" stroke-linecap="round"/>
                <line x1="7" y1="10" x2="30" y2="14" stroke="url(#armG)" stroke-width="3" stroke-linecap="round"/>
                <circle cx="-30" cy="0" r="3" fill="#5a9a2a"/><circle cx="30" cy="0" r="3" fill="#5a9a2a"/>
                <circle cx="-30" cy="14" r="3" fill="#5a9a2a"/><circle cx="30" cy="14" r="3" fill="#5a9a2a"/>
                <ellipse cx="0" cy="6" rx="12" ry="8" fill="url(#bodyG)"/>
              </g>
            </g>
            <!-- Flight path dashes -->
            <path d="M250,75 C200,90 120,95 80,110" stroke="#77B940" stroke-width="0.8" stroke-dasharray="4 6" opacity="0.2" fill="none"/>
            <path d="M250,75 C300,90 380,100 420,130" stroke="#77B940" stroke-width="0.8" stroke-dasharray="4 6" opacity="0.2" fill="none"/>
            <path d="M80,110 C60,150 45,180 45,210" stroke="#77B940" stroke-width="0.6" stroke-dasharray="3 5" opacity="0.15" fill="none"/>
            <path d="M420,130 C440,170 455,200 460,230" stroke="#77B940" stroke-width="0.6" stroke-dasharray="3 5" opacity="0.15" fill="none"/>
          </svg>
        </div>
      </div>
      <div class="how-scene" data-scene="1">
        <div class="how-scene-bg"><canvas class="scene-cv" data-sid="1"></canvas></div>
        <div class="how-scene-content">
          <div class="hsc-number">02</div>
          <h3 class="hsc-title">AI-Powered Scanning</h3>
